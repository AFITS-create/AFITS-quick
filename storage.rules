rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.isAdmin == true;
    }

    match /products/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    match /banners/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
      allow create, update: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('video/(mp4|webm)');
      allow delete: if isAdmin();
    }

    match /invoices/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('(application/pdf|image/png|image/jpeg|image/webp)');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
